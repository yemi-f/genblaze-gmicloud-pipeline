# Project root .env — copy to `.env` (same directory) and fill in real values.
# The FastAPI service reads this file via an absolute path, so it works
# regardless of which directory you run pnpm/uvicorn from.

# Backblaze B2
B2_ENDPOINT=https://s3.<region>.backblazeb2.com
B2_REGION=<region>
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=

# GMICloud — obtain at https://gmicloud.ai/
GMI_API_KEY=

# Optional tuning
STEP_CACHE_DIR=./.cache/genblaze     # local cache; same-prompt+seed skips GMI calls
OTEL_ENDPOINT=                        # if set, OTelTracer is added to CompositeTracer
WEBHOOK_URL=                          # if set, WebhookSink posts run completion events
WEBHOOK_HEADER_AUTHORIZATION=         # optional Bearer token for the webhook endpoint

# Override if your Next dev server runs on a different origin.
# Default allows localhost:3000 and :3001.
# API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
